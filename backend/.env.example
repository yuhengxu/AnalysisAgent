# 大模型提供商：volcengine | deepseek | openai | mock
DEFAULT_LLM_PROVIDER=volcengine

# ============ 调用模式说明 ============
# 平台所有大模型调用支持两类模式（由前端/请求体 mode 字段控制）：
# - normal        普通模式：直接调用对话模型，响应快
# - deep_research 深度研究模式：
#     * DeepSeek  → 开启深度思考（thinking + reasoning_effort）
#     * 豆包      → 调用 DeepSearch 智能体（集成浏览器使用、联网搜索、知识库、
#                   网页解析、ChatPPT、Python 代码执行器等 MCP 服务）

# 火山方舟豆包（OpenAI 兼容，生产默认）
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-seed-2-0-pro-260215
# 方舟已验证 model 字段（设置页可选）：
#   doubao-seed-2-1-pro-260628   Doubao-Seed-2.1-pro
#   doubao-seed-2-1-turbo-260628 Doubao-Seed-2.1-turbo
#   doubao-seed-evolving         Doubao-Seed-Evolving
#   doubao-seed-2-0-pro-260215   Doubao-Seed-2.0-pro
#   doubao-seed-2-0-lite-260215  Doubao-Seed-2.0-lite
#   deepseek-v4-pro              DeepSeek-V4-pro
#   deepseek-v4-flash            DeepSeek-V4-flash
# 可选：覆盖/追加火山方舟模型目录（JSON 数组，供前端设置页展示）
# VOLCENGINE_MODEL_CATALOG=[{"id":"your-endpoint-id","label":"自定义模型","family":"custom","hint":"说明"}]
# DeepSearch 智能体应用 ID（bot-xxx）：方舟控制台 → 应用广场 → DeepSearch → 创建应用
# 未配置时，豆包深度研究模式自动降级为普通模式
VOLCENGINE_DEEPSEARCH_BOT_ID=

# DeepSeek（OpenAI 兼容，兼容保留）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# 深度研究模式下的思考强度：high（标准）| max（最强，耗时显著更长）
DEEPSEEK_REASONING_EFFORT=high

# OpenAI 兼容（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 普通调用超时（秒）；深度研究模式（深度思考 / DeepSearch）使用 LLM_DEEP_TIMEOUT
LLM_TIMEOUT=600
LLM_DEEP_TIMEOUT=900

DATABASE_URL=sqlite:///./db/energy_platform.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT 鉴权
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 月报图表渲染引擎：matplotlib（默认）| echarts（需 playwright install chromium）
CHART_RENDERER=matplotlib
# echarts 失败时是否回退 matplotlib（默认 false，需显式开启）
CHART_ECHARTS_FALLBACK=false
CHART_ECHARTS_WIDTH=1400
CHART_ECHARTS_HEIGHT=780
CHART_ECHARTS_DEVICE_SCALE=3
PLAYWRIGHT_BROWSER=chromium

# 表2-2 GDP 增速：深度研究联网时是否默认调用大模型预测（false=仅手工填写，前端可单次勾选覆盖）
REPORT_TABLE_GDP_LLM_PREDICT=false
